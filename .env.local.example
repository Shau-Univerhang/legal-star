# Supabase credentials - copy to .env.local and fill in values
# Get these from: https://app.supabase.com/project/_/settings/api

# Project URL (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key (for client or server read)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (optional; use for API routes to bypass RLS - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Coze AI Configuration
# Base URL for Coze API (defaults to https://api.coze.cn)
COZE_API_BASE_URL=https://api.coze.cn
# Your Personal Access Token from Coze
COZE_API_TOKEN=your-coze-api-token
# The Bot ID you created in Coze
COZE_BOT_ID=your-coze-bot-id
